{
	"name": "campus-cafe",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"lucide-react": "^0.546.0",
			"next-themes": "^0.4.6",
			"react": "^19.2.3",
			"react-dom": "^19.2.3",
			"sonner": "^2.0.5",
			"convex": "^1.33.1",
			"better-auth": "1.5.3",
			"@convex-dev/better-auth": "^0.11.3",
			"@types/react": "^19.2.10",
			"@types/react-dom": "^19.2.3",
			"tailwindcss": "^4.1.18",
			"alchemy": "^0.90.0"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F @campus-cafe/backend dev",
		"dev:setup": "turbo -F @campus-cafe/backend dev:setup",
		"deploy": "turbo -F @campus-cafe/infra deploy",
		"destroy": "turbo -F @campus-cafe/infra destroy",
		"check": "biome check --write ."
	},
	"dependencies": {
		"@campus-cafe/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@campus-cafe/config": "workspace:*",
		"@cloudflare/workers-types": "^4.20251213.0",
		"alchemy": "catalog:",
		"turbo": "^2.8.12",
		"typescript": "^5"
	},
	"packageManager": "bun@1.3.11"
}
